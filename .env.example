# Backend Django Configuration
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,yourdomain.com

# Database - SQLite (Development)
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3

# Database - PostgreSQL (Production with Supabase)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.cuwaspbwlefzvuforuen.supabase.co:5432/postgres

# API Keys
GOOGLE_API_KEY=your-google-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# AWS S3 Configuration (for document storage)
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_STORAGE_BUCKET_NAME=doc-check-iheb
AWS_S3_REGION_NAME=eu-west-1
AWS_S3_CUSTOM_DOMAIN=%(bucket_name)s.s3.amazonaws.com

# DocCheck Service
DOCCHECK_API_KEY=your-doccheck-api-key-here
REZERVA_PARTNER_KEY=your-rezerva-partner-key-here
WEBHOOK_SECRET=your-webhook-secret-for-hmac-signing

# Frontend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_APP_NAME=PFE Seller Platform

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO
